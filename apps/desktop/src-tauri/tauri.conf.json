{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "X-File",
  "version": "0.1.0-beta.1",
  "identifier": "top.codingns.xfile",
  "build": {
    "beforeDevCommand": "pnpm --filter @x-file/web dev",
    "devUrl": "http://127.0.0.1:17320",
    "beforeBuildCommand": "pnpm --filter @x-file/shared build && pnpm --filter @x-file/indexer build && pnpm --filter @x-file/web build && pnpm --filter @x-file/server build && node ../../scripts/prepare-bundled-server.mjs",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "X-File",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "label": "main",
        "resizable": true,
        "acceptFirstMouse": true,
        "transparent": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 15
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "X-File 文档库独立应用",
    "longDescription": "X-File 是从 CodingNS 拆出的本机文档库应用。签名和自动更新配置已预留，发布前必须替换真实 secrets 并在实机 runner 验证。",
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/x-file-server": "x-file-server",
      "resources/x-file-runtime": "x-file-runtime"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4N0ExMDM3REVDNkIwMDQKUldRRXNNYmVOeEI2S096UlU1cXlJUlBIYXJZcXlUVWVzM3gvRi9FckRjZHJzRHd5RmtGdkdMMW4K",
      "endpoints": [
        "https://github.com/jingyi0605/X-File/releases/latest/download/latest.json"
      ]
    }
  }
}
